ID=offline-quick-suite
TITLE=Offline Quick Suite
DESCRIPTION=Run the quick suite from the warmed dataset cache with remote downloads disabled.
TIMEOUT_SECONDS=86400
CWD={{repo}}
POSIX_PROGRAM=./start.sh
POSIX_ARGS=--|quick|--samples|3|--offline
WINDOWS_PROGRAM=cmd
WINDOWS_ARGS=/c|start.bat|--|quick|--samples|3|--offline
