ID=cache-quick-suite
TITLE=Warm Quick Cache
DESCRIPTION=Cache quick-suite benchmark rows for later offline runs.
TIMEOUT_SECONDS=7200
CWD={{repo}}
POSIX_PROGRAM=./start.sh
POSIX_ARGS=--|cache|--benchmarks|quick_suite|--samples|3
WINDOWS_PROGRAM=cmd
WINDOWS_ARGS=/c|start.bat|--|cache|--benchmarks|quick_suite|--samples|3
