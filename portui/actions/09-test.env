ID=test
TITLE=Run Tests
DESCRIPTION=Run the repository unit test suite.
TIMEOUT_SECONDS=7200
CWD={{repo}}
POSIX_PROGRAM=sh
POSIX_ARGS=-c|./start.sh --check-only && exec ./.venv/bin/python test_everything.py
WINDOWS_PROGRAM=cmd
WINDOWS_ARGS=/c|call start.bat --check-only && .\\.venv\\Scripts\\python.exe test_everything.py
