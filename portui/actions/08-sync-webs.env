ID=sync-webs
TITLE=Sync websmaLLMs
DESCRIPTION=Export the latest run and mirror the latest session bundle into the sibling websmaLLMs repo.
TIMEOUT_SECONDS=1800
CWD={{repo}}
POSIX_PROGRAM=./start.sh
POSIX_ARGS=--|export|--sync-dir|{{webPublicData}}
WINDOWS_PROGRAM=cmd
WINDOWS_ARGS=/c|start.bat|--|export|--sync-dir|{{webPublicData}}
